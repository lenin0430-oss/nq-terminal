<script>
// ─── STATE ───────────────────────────────────────────────────────────────────
const S = {
  apiKey: '',
  tgToken: '',
  tgChatId: '',
  priceSrc: 'yahoo',
  price: 0,
  priceManual: false,
  bias: { d:'',h7:'',h4:'',h1:'' },
  lastAnalysis: null,
  tgMsg: '',
  log: []
};

// ─── INIT ─────────────────────────────────────────────────────────────────────
(function init(){
  const k = localStorage.getItem('nq_cfg');
  if(k){ const c=JSON.parse(k); S.apiKey=c.apiKey||''; S.tgToken=c.tgToken||''; S.tgChatId=c.tgChatId||''; S.priceSrc=c.priceSrc||'yahoo'; }
  const log = localStorage.getItem('nq_log');
  if(log){ S.log = JSON.parse(log); renderLog(); }
  if(!S.apiKey) setTimeout(openModal, 600);
  updateClock();
  setInterval(updateClock, 30000);
  if(S.priceSrc === 'yahoo') fetchPrice();
  setInterval(()=>{ if(S.priceSrc==='yahoo' && !S.priceManual) fetchPrice(); }, 60000);
})();

// ─── CLOCK & SESSION ─────────────────────────────────────────────────────────
function getNYTime(){
  const now = new Date();
  // NY is UTC-4 (EDT) in March
  const nyOffset = -4;
  const utc = now.getTime() + now.getTimezoneOffset()*60000;
  const ny = new Date(utc + nyOffset*3600000);
  return ny;
}

function updateClock(){
  const ny = getNYTime();
  const h = ny.getHours(), m = ny.getMinutes();
  const hh = String(h).padStart(2,'0'), mm = String(m).padStart(2,'0');
  document.getElementById('ny-time').textContent = `NY ${hh}:${mm}`;

  const badge = document.getElementById('sess-badge');
  const totalMin = h*60+m;
  // NY session 9:30 - 16:00
  if(totalMin >= 570 && totalMin < 960){
    badge.className='session-badge s-open'; badge.textContent='SESIÓN ABIERTA';
  } else if(totalMin >= 240 && totalMin < 570){
    badge.className='session-badge s-pre'; badge.textContent='PRE-MARKET';
  } else {
    badge.className='session-badge s-closed'; badge.textContent='MERCADO CERRADO';
  }
}

function getSessionPhase(){
  const ny = getNYTime();
  const totalMin = ny.getHours()*60 + ny.getMinutes();
  if(totalMin < 570) return { open:false, phase:'Pre-market o cerrado', risk:'NO OPERAR — fuera de sesión NY' };
  if(totalMin >= 570 && totalMin < 630) return { open:true, phase:'Apertura NY (9:30–10:30 ET)', risk:'Alta volatilidad — spreads grandes' };
  if(totalMin >= 630 && totalMin < 750) return { open:true, phase:'Media mañana (10:30–12:30 ET)', risk:'Buena liquidez' };
  if(totalMin >= 750 && totalMin < 840) return { open:true, phase:'Lunch hour NY (12:30–14:00 ET)', risk:'Volumen bajo — evitar entradas' };
  if(totalMin >= 840 && totalMin < 960) return { open:true, phase:'Tarde NY (14:00–16:00 ET)', risk:'Buena liquidez — posibles reversals al cierre' };
  return { open:false, phase:'Después del cierre', risk:'NO OPERAR' };
}

// ─── PRICE ───────────────────────────────────────────────────────────────────
async function fetchPrice(){
  try {
    const url = `https://api.allorigins.win/raw?url=${encodeURIComponent('https://query1.finance.yahoo.com/v8/finance/chart/NQ%3DF?interval=1m&range=1d')}`;
    const r = await fetch(url);
    const d = await r.json();
    const meta = d.chart.result[0].meta;
    const p = meta.regularMarketPrice || meta.previousClose;
    if(p){
      S.price = p;
      document.getElementById('nq-price').textContent = p.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
      const prev = meta.previousClose || p;
      const chg = ((p-prev)/prev*100).toFixed(2);
      const chgEl = document.getElementById('nq-chg');
      chgEl.textContent = `NQ JUN26  ${chg >= 0 ? '+' : ''}${chg}%`;
      chgEl.style.color = chg >= 0 ? 'var(--green)' : 'var(--red)';
    }
  } catch(e){
    document.getElementById('nq-price').textContent = 'N/D';
  }
}

function togglePriceMode(){
  S.priceManual = !S.priceManual;
  document.getElementById('price-mode').textContent = S.priceManual ? '✎ manual' : '⟳ auto';
  if(!S.priceManual) fetchPrice();
}

// ─── VOL PREVIEW ─────────────────────────────────────────────────────────────
function renderVol(inputId, previewId){
  const vals = document.getElementById(inputId).value.split(',').map(v=>parseFloat(v.trim())).filter(v=>!isNaN(v));
  const prev = document.getElementById(previewId);
  prev.innerHTML = '';
  if(!vals.length) return;
  const mx = Math.max(...vals.map(Math.abs)) || 1;
  vals.forEach(v=>{
    const h = Math.max(4, Math.round(Math.abs(v)/mx*26));
    const b = document.createElement('div');
    b.className = `vb ${v>=0?'u':'d'}`;
    b.style.cssText = `width:${Math.floor(228/vals.length)-3}px;height:${h}px`;
    prev.appendChild(b);
  });
}

// ─── BIAS ─────────────────────────────────────────────────────────────────────
function setBias(btn){
  const tf = btn.dataset.tf, val = btn.dataset.v;
  // Clear siblings
  btn.closest('.bias-btns').querySelectorAll('.bb').forEach(b=>{
    b.className='bb';
  });
  S.bias[tf] = val;
  if(val==='ALCISTA') btn.classList.add('bull');
  else if(val==='BAJISTA') btn.classList.add('bear');
  else btn.classList.add('neu');
}

// ─── CONFIG MODAL ─────────────────────────────────────────────────────────────
function openModal(){
  document.getElementById('cfg-apikey').value = S.apiKey;
  document.getElementById('cfg-tg-token').value = S.tgToken;
  document.getElementById('cfg-tg-chatid').value = S.tgChatId;
  document.getElementById('cfg-price-src').value = S.priceSrc;
  document.getElementById('modal').classList.add('open');
}
function closeModal(){ document.getElementById('modal').classList.remove('open'); }
function saveConfig(){
  S.apiKey = document.getElementById('cfg-apikey').value.trim();
  S.tgToken = document.getElementById('cfg-tg-token').value.trim();
  S.tgChatId = document.getElementById('cfg-tg-chatid').value.trim();
  S.priceSrc = document.getElementById('cfg-price-src').value;
  localStorage.setItem('nq_cfg', JSON.stringify({apiKey:S.apiKey,tgToken:S.tgToken,tgChatId:S.tgChatId,priceSrc:S.priceSrc}));

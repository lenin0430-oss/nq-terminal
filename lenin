}

// ─── AGENT HELPERS ───────────────────────────────────────────────────────────
function setAgentThinking(n){
  document.getElementById(`card-ag${n}`).className='ag-card thinking';
  document.getElementById(`dot-ag${n}`).className='ag-dot thinking';
  document.getElementById(`out-ag${n}`).className='ag-body';
  document.getElementById(`out-ag${n}`).textContent='Analizando...';
}
function setAgentDone(n, text, mode='neu'){
  document.getElementById(`card-ag${n}`).className=`ag-card ${mode}`;
  document.getElementById(`dot-ag${n}`).className=`ag-dot ${mode}`;
  const el = document.getElementById(`out-ag${n}`);
  el.className='ag-body ready fade-up';
  el.textContent = text;
}
function setAgentWait(n, msg){
  document.getElementById(`card-ag${n}`).className='ag-card';
  document.getElementById(`dot-ag${n}`).className='ag-dot';
  document.getElementById(`out-ag${n}`).className='ag-body';
  document.getElementById(`out-ag${n}`).textContent = msg||'Esperando...';
}

async function callClaude(systemPrompt, userMsg){
  const r = await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json','x-api-key':S.apiKey,'anthropic-version':'2023-06-01'},
    body: JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:400,
      system: systemPrompt,
      messages:[{role:'user',content:userMsg}]
    })
  });
  const d = await r.json();
  if(d.error) throw new Error(d.error.message);
  return d.content[0].text;
}

// ─── MAIN ANALYSIS ───────────────────────────────────────────────────────────

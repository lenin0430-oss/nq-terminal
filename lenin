  if(slP) document.getElementById('rv-sl').textContent = parseFloat(slP).toLocaleString('en-US',{minimumFractionDigits:2});
  if(tp1P) document.getElementById('rv-tp').textContent = parseFloat(tp1P).toLocaleString('en-US',{minimumFractionDigits:2});
  if(contrs) document.getElementById('rv-contr').textContent = `${contrs} NQ`;
  if(riesgoR){
    document.getElementById('rv-risk').textContent = `$${parseFloat(riesgoR).toLocaleString('en-US')}`;
    document.getElementById('rv-risk-pct').textContent = `${riesgoPct || '2.00'}% capital`;
  }
  if(gananciaR){
    document.getElementById('rv-gain').textContent = `$${parseFloat(gananciaR).toLocaleString('en-US')}`;
    document.getElementById('rv-gain-pct').textContent = `${gananciaPct || '2.00'}% capital`;
  }
  document.getElementById('rr-badge').textContent = 'RR 1:1';
  const efect = (r4.match(/EFECTIVIDAD:[^
]+/i)||['','N/A'])[1].trim().replace('EFECTIVIDAD:','').trim();
  const efEl = document.getElementById('efect-badge');
  if(efEl){
    efEl.textContent = 'Efect. '+efect;
    if(efect.includes('92')){efEl.style.color='var(--green)';efEl.style.borderColor='var(--green)';}
    else if(efect.includes('54')){efEl.style.color='var(--amber)';efEl.style.borderColor='var(--amber)';}
  }
  // Efectividad
  const efect = r4.match(/EFECTIVIDAD:\s*([^
]+)/i)?.[1]?.trim() || 'N/A';
  const efEl = document.getElementById('efect-badge');
  if(efEl){
    efEl.textContent = 'Efect. '+efect;
    if(efect.includes('92')) { efEl.style.color='var(--green)'; efEl.style.borderColor='var(--green)'; }
    else if(efect.includes('54')) { efEl.style.color='var(--amber)'; efEl.style.borderColor='var(--amber)'; }
    else { efEl.style.color='var(--muted)'; efEl.style.borderColor='var(--border2)'; }
  }

  // ── FASE 4: AG6 - Alerta Telegram ─────────────────────────────────────────
  setAgentThinking(6);
  const r6 = await callClaude(
    `Eres AG6, formateador de alertas de Telegram para LeninTrader NQ. Responde solo con el mensaje de Telegram listo para enviar.
Usa exactamente este formato con emojis y las líneas ━━━ como separadores.
No agregues texto antes ni después del mensaje.`,
    `Señal: ${senal}
Confianza: ${conf}
Entrada: ${entrada.toFixed(2)}
SL y TP: ${r5}
AG4 decisión: ${r4}
Hora NY: ${horaET}
Sesión: ${session.phase}
Vol 5M: ${vol5m} | Presión: ${pres5m}
Vol 1M: ${vol1m} | Presión: ${pres1m}
Bias estructura: D:${S.bias.d} 7H:${S.bias.h7} 4H:${S.bias.h4} 1H:${S.bias.h1}

Crea el mensaje de alerta para Telegram con formato limpio y los datos del setup.`
  ).then(r=>{ setAgentDone(6,r,'neu'); return r; });

  // Update Telegram preview
  S.tgMsg = r6;
  const tgPrev = document.getElementById('tg-preview');
  tgPrev.textContent = r6;
  tgPrev.className = 'ready';
  document.getElementById('btn-tg').disabled = false;

  // Save to log
  const logEntry = {
    hora: horaET,
    senal,
    entrada: entrada.toFixed(2),
    sl: slP || '—',
    tp: tp1P || '—',
    contrs: contrs ? `${contrs} NQ` : '—',
    ts: Date.now()
  };
  S.log.unshift(logEntry);
  if(S.log.length > 20) S.log = S.log.slice(0,20);
  localStorage.setItem('nq_log', JSON.stringify(S.log));
  renderLog();

  btn.disabled = false; btn.textContent = '▶ ANALIZAR';
}

// ─── TELEGRAM ─────────────────────────────────────────────────────────────────
async function sendTelegram(){
  if(!S.tgToken || !S.tgChatId){ alert('Configura el Bot Token y Chat ID en ⚙ Config'); return; }
  const btn = document.getElementById('btn-tg');
  btn.disabled = true; btn.textContent = '⏳ Enviando...';
  document.getElementById('tg-status').textContent = 'enviando...';
  try{
    const r = await fetch(`https://api.telegram.org/bot${S.tgToken}/sendMessage`,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ chat_id: S.tgChatId, text: S.tgMsg, parse_mode:'HTML' })
    });
    const d = await r.json();
    if(d.ok){
      document.getElementById('tg-status').style.color='var(--green)';
      document.getElementById('tg-status').textContent='✓ enviado';
      btn.textContent='✓ Enviado';
      setTimeout(()=>{ btn.textContent='▶ Enviar a Telegram'; btn.disabled=false; document.getElementById('tg-status').textContent='—'; document.getElementById('tg-status').style.color=''; },3000);
    } else {
      throw new Error(d.description);
    }
  }catch(e){
    document.getElementById('tg-status').style.color='var(--red)';
    document.getElementById('tg-status').textContent='✕ error';
    btn.textContent='✕ Error — reintentar';
    btn.disabled=false;
    alert('Error Telegram: '+e.message);
  }
}

// ─── LOG ──────────────────────────────────────────────────────────────────────
function renderLog(){
  const body = document.getElementById('log-body');
  const empty = document.getElementById('log-empty');
  if(!S.log.length){ if(empty) empty.style.display='block'; return; }
  if(empty) empty.style.display='none';
  // Remove old rows except header
  body.querySelectorAll('.log-row:not(.log-hdr)').forEach(r=>r.remove());
  S.log.forEach(e=>{
    const row = document.createElement('div');
    row.className='log-row';
    const tag = e.senal==='LONG'?'L':e.senal==='SHORT'?'S':'H';
    row.innerHTML=`<span>${e.hora}</span><span><span class="tag ${tag}">${e.senal}</span></span><span>${e.entrada}</span><span style="color:var(--red)">${e.sl}</span><span style="color:var(--green)">${e.tp}</span><span>${e.contrs}</span>`;
    body.appendChild(row);
  });
}

function clearLog(){
  S.log=[];
  localStorage.removeItem('nq_log');
  document.getElementById('log-body').querySelectorAll('.log-row:not(.log-hdr)').forEach(r=>r.remove());
  const empty = document.getElementById('log-empty');
  if(empty) empty.style.display='block';
}
</script>

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LeninTrader NQ · Terminal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#080b0f;--bg2:#0e1318;--bg3:#151c24;--bg4:#1c242e;
  --border:#1e2830;--border2:#263040;
  --text:#dde3ea;--muted:#4a5a6a;--dim:#6b7e8f;
  --green:#00e676;--red:#ff4466;--amber:#ffb300;--blue:#40c8f4;--purple:#c084fc;
  --long:#00c853;--short:#ff1744;--hold:#ff8f00;
  --r:5px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:'Space Mono',monospace;font-size:12px;}

/* Scrollbar */
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* Header */
#hdr{
  height:50px;background:var(--bg2);border-bottom:1px solid var(--border2);
  display:flex;align-items:center;gap:16px;padding:0 16px;
  position:relative;z-index:10;
}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:var(--amber);letter-spacing:-0.5px;white-space:nowrap;}
.logo b{color:var(--text);}
#nq-price{font-size:20px;font-weight:700;color:var(--green);font-variant-numeric:tabular-nums;letter-spacing:-0.5px;}
#nq-chg{font-size:11px;color:var(--muted);}
#sess-badge{
  padding:3px 9px;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:1px;
  border:1px solid;white-space:nowrap;
}
.s-open{background:rgba(0,230,118,.1);color:var(--green);border-color:var(--green);}
.s-closed{background:rgba(255,68,102,.1);color:var(--red);border-color:var(--red);}
.s-pre{background:rgba(255,179,0,.1);color:var(--amber);border-color:var(--amber);}
#ny-time{font-size:10px;color:var(--dim);}
.hdr-r{margin-left:auto;display:flex;align-items:center;gap:10px;}
.icon-btn{
  background:transparent;border:1px solid var(--border2);color:var(--muted);
  border-radius:var(--r);padding:5px 10px;cursor:pointer;font-family:'Space Mono',monospace;font-size:11px;
  transition:all .15s;
}
.icon-btn:hover{border-color:var(--amber);color:var(--amber);}

/* Layout */
#layout{display:grid;grid-template-columns:272px 1fr;height:calc(100vh - 50px);}

/* Sidebar */
#sidebar{
  background:var(--bg2);border-right:1px solid var(--border);
  overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:12px;
}
.sec-title{
  font-size:9px;font-weight:700;letter-spacing:2px;color:var(--muted);
  text-transform:uppercase;padding-bottom:6px;border-bottom:1px solid var(--border);
  margin-bottom:6px;
}
.field{display:flex;flex-direction:column;gap:3px;}
.field label{font-size:9px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;}
.field input,.field select,.field textarea{
  background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r);
  color:var(--text);padding:6px 9px;font-family:'Space Mono',monospace;font-size:11px;
  width:100%;outline:none;transition:border-color .2s;
}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--amber);}
.field textarea{resize:none;height:52px;}
select option{background:var(--bg3);}

/* Timeframe bias */
.tf-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.tf-row{display:flex;flex-direction:column;gap:3px;}
.tf-row .lbl{font-size:9px;color:var(--dim);letter-spacing:1px;}
.bias-btns{display:flex;gap:3px;}
.bb{
  flex:1;padding:4px 2px;border:1px solid var(--border2);border-radius:3px;
  background:var(--bg3);color:var(--muted);font-family:'Space Mono',monospace;
  font-size:9px;cursor:pointer;text-align:center;letter-spacing:.5px;transition:all .15s;
}
.bb:hover{border-color:var(--border2);color:var(--text);}
.bb.bull{background:rgba(0,230,118,.12);color:var(--green);border-color:var(--green);}
.bb.bear{background:rgba(255,68,102,.12);color:var(--red);border-color:var(--red);}
.bb.neu{background:rgba(255,179,0,.08);color:var(--amber);border-color:var(--amber);}

/* Analyze button */
#btn-analyze{
  width:100%;padding:11px;background:var(--amber);color:#000;
  border:none;border-radius:var(--r);
  font-family:'Syne',sans-serif;font-weight:800;font-size:13px;letter-spacing:.5px;
  cursor:pointer;transition:all .2s;
}
#btn-analyze:hover:not(:disabled){background:#ffc107;box-shadow:0 0 20px rgba(255,179,0,.3);}
#btn-analyze:disabled{background:var(--border2);color:var(--muted);cursor:not-allowed;}

/* Vol visualizer */
.vol-preview{display:flex;gap:2px;align-items:flex-end;height:28px;margin-top:4px;}
.vb{border-radius:1px 1px 0 0;transition:height .3s;}
.vb.u{background:var(--green);}
.vb.d{background:var(--red);}

/* Content */
#content{overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:14px;}

/* Decision hero */
#dec-card{
  background:var(--bg2);border:1px solid var(--border);border-radius:8px;
  padding:16px 20px;display:flex;align-items:center;gap:24px;min-height:80px;
}
#dec-signal{
  font-family:'Syne',sans-serif;font-weight:800;font-size:42px;
  letter-spacing:-2px;min-width:130px;
  text-shadow:0 0 30px currentColor;
  transition:color .3s;
}
#dec-signal.LONG{color:var(--long);}
#dec-signal.SHORT{color:var(--short);}
#dec-signal.HOLD{color:var(--hold);}
#dec-signal.WAIT{color:var(--muted);}
.risk-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0;flex:1;}
.ri{display:flex;flex-direction:column;gap:3px;padding:0 16px;border-right:1px solid var(--border);}
.ri:first-child{padding-left:0;}
.ri:last-child{border-right:none;}
.rl{font-size:9px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;}
.rv{font-size:16px;font-weight:700;font-variant-numeric:tabular-nums;}
.rv.g{color:var(--long);}
.rv.r{color:var(--short);}
.rv.a{color:var(--amber);}
#conf-badge{
  padding:3px 8px;border-radius:3px;font-size:9px;font-weight:700;letter-spacing:1px;
  border:1px solid var(--muted);color:var(--muted);
}
#conf-badge.ALTA{border-color:var(--green);color:var(--green);background:rgba(0,230,118,.1);}
#conf-badge.MEDIA{border-color:var(--amber);color:var(--amber);background:rgba(255,179,0,.1);}
#conf-badge.BAJA{border-color:var(--red);color:var(--red);background:rgba(255,68,102,.1);}

/* Agents grid */
.agents-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.ag-card{
  background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);
  overflow:hidden;transition:border-color .3s;
}
.ag-card.thinking{border-color:var(--amber);}
.ag-card.bull{border-color:rgba(0,230,118,.4);}
.ag-card.bear{border-color:rgba(255,68,102,.4);}
.ag-card.neu{border-color:var(--border2);}
.ag-hdr{
  padding:7px 12px;background:var(--bg3);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.ag-id{font-size:9px;color:var(--amber);font-weight:700;letter-spacing:1.5px;}
.ag-name{font-size:10px;color:var(--dim);}
.ag-dot{width:7px;height:7px;border-radius:50%;background:var(--border2);transition:background .3s;}
.ag-dot.thinking{background:var(--amber);animation:pulse 1s infinite;}
.ag-dot.bull{background:var(--green);}
.ag-dot.bear{background:var(--red);}
.ag-dot.neu{background:var(--muted);}
.ag-body{padding:10px 12px;min-height:88px;font-size:11px;line-height:1.7;color:var(--muted);}
.ag-body.ready{color:var(--text);}

/* Bottom row */
.bottom-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.panel{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;}
.panel-hdr{
  padding:7px 12px;background:var(--bg3);border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.panel-title{font-size:9px;color:var(--muted);font-weight:700;letter-spacing:2px;text-transform:uppercase;}
.panel-body{padding:10px 12px;}

/* Telegram */
#tg-preview{
  background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);
  padding:10px;font-size:10px;line-height:1.8;color:var(--dim);
  min-height:80px;white-space:pre-wrap;margin-bottom:10px;
}
#tg-preview.ready{color:var(--text);}
#btn-tg{
  width:100%;padding:8px;
  background:rgba(64,200,244,.08);border:1px solid rgba(64,200,244,.3);color:var(--blue);
  border-radius:var(--r);font-family:'Space Mono',monospace;font-size:11px;
  cursor:pointer;transition:all .2s;
}
#btn-tg:hover:not(:disabled){background:rgba(64,200,244,.15);}
#btn-tg:disabled{opacity:.35;cursor:not-allowed;}

/* Log */
#log-body{overflow-y:auto;max-height:160px;}
.log-row{
  display:grid;grid-template-columns:70px 50px 90px 90px 90px 1fr;
  gap:0;padding:6px 12px;border-bottom:1px solid var(--border);
  font-size:10px;align-items:center;
}
.log-row:last-child{border-bottom:none;}
.log-hdr{background:var(--bg3);color:var(--muted);font-size:9px;letter-spacing:1px;}
.tag{padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700;}
.tag.L{background:rgba(0,200,83,.15);color:var(--long);}
.tag.S{background:rgba(255,23,68,.15);color:var(--short);}
.tag.H{background:rgba(255,143,0,.15);color:var(--hold);}
.log-empty{padding:20px 12px;color:var(--muted);font-size:11px;text-align:center;}

/* Modal */
#modal{
  position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:999;
  display:none;align-items:center;justify-content:center;
}
#modal.open{display:flex;}
.modal-box{
  background:var(--bg2);border:1px solid var(--border2);border-radius:8px;
  padding:24px;width:380px;display:flex;flex-direction:column;gap:14px;
}
.modal-box h3{font-family:'Syne',sans-serif;font-size:15px;color:var(--amber);}
.modal-box p{font-size:11px;color:var(--dim);line-height:1.6;}
.modal-btns{display:flex;gap:8px;margin-top:4px;}
.btn-save{
  flex:1;padding:9px;background:var(--amber);color:#000;border:none;
  border-radius:var(--r);font-family:'Space Mono',monospace;font-size:12px;
  font-weight:700;cursor:pointer;
}
.btn-cancel{
  padding:9px 16px;background:transparent;border:1px solid var(--border2);
  color:var(--muted);border-radius:var(--r);font-family:'Space Mono',monospace;
  font-size:12px;cursor:pointer;
}
.btn-cancel:hover{border-color:var(--red);color:var(--red);}

/* Animations */
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.fade-up{animation:fadeUp .3s ease-out;}
</style>
</head>
<body>

<!-- HEADER -->
<div id="hdr">
  <div class="logo">Lenin<b>Trade</b><span style="color:var(--amber)">R</span> <span style="font-size:11px;color:var(--muted);font-family:'Space Mono',monospace;font-weight:400;">NQ Terminal</span></div>
  <div style="display:flex;flex-direction:column;gap:1px;">
    <span id="nq-price">—</span>
    <span id="nq-chg">NQ JUN26</span>
  </div>
  <div id="sess-badge" class="s-closed">CARGANDO</div>
  <div id="ny-time">NY —:—</div>
  <div class="hdr-r">
    <div id="price-mode" style="font-size:10px;color:var(--muted);cursor:pointer;" title="Click para ingresar precio manual" onclick="togglePriceMode()">⟳ auto</div>
    <button class="icon-btn" onclick="openModal()">⚙ Config</button>
  </div>
</div>

<!-- LAYOUT -->
<div id="layout">

  <!-- SIDEBAR -->
  <div id="sidebar">

    <div>
      <div class="sec-title">Indicadores NinjaTrader</div>

      <div style="display:flex;flex-direction:column;gap:9px;">

        <div class="field">
          <label>VolumenDominanciaF · 5M (últimas 5 velas)</label>
          <input type="text" id="vol5m" placeholder="293,-145,412,-89,200" oninput="renderVol('vol5m','prev5m')">
          <div class="vol-preview" id="prev5m"></div>
        </div>

        <div class="field">
          <label>VolumenDominanciaF · 1M (últimas 5 velas)</label>
          <input type="text" id="vol1m" placeholder="120,88,-45,210,-30" oninput="renderVol('vol1m','prev1m')">
          <div class="vol-preview" id="prev1m"></div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
          <div class="field">
            <label>Presión 5M</label>
            <select id="pres5m">
              <option value="NEUTRO">— Neutro</option>
              <option value="COMPRA">▲ Compra</option>
              <option value="VENTA">▼ Venta</option>
            </select>
          </div>
          <div class="field">
            <label>Presión 1M</label>
            <select id="pres1m">
              <option value="NEUTRO">— Neutro</option>
              <option value="COMPRA">▲ Compra</option>
              <option value="VENTA">▼ Venta</option>
            </select>
          </div>
        </div>

      </div>
    </div>

    <div>
      <div class="sec-title">Estructura Multi-TF</div>
      <div class="tf-grid">
        <div class="tf-row"><div class="lbl">Diario</div><div class="bias-btns"><button class="bb" data-tf="d" data-v="ALCISTA" onclick="setBias(this)">▲ Alc</button><button class="bb" data-tf="d" data-v="BAJISTA" onclick="setBias(this)">▼ Baj</button><button class="bb" data-tf="d" data-v="NEUTRO" onclick="setBias(this)">— Neu</button></div></div>
        <div class="tf-row"><div class="lbl">7 Horas</div><div class="bias-btns"><button class="bb" data-tf="h7" data-v="ALCISTA" onclick="setBias(this)">▲ Alc</button><button class="bb" data-tf="h7" data-v="BAJISTA" onclick="setBias(this)">▼ Baj</button><button class="bb" data-tf="h7" data-v="NEUTRO" onclick="setBias(this)">— Neu</button></div></div>
        <div class="tf-row"><div class="lbl">4 Horas</div><div class="bias-btns"><button class="bb" data-tf="h4" data-v="ALCISTA" onclick="setBias(this)">▲ Alc</button><button class="bb" data-tf="h4" data-v="BAJISTA" onclick="setBias(this)">▼ Baj</button><button class="bb" data-tf="h4" data-v="NEUTRO" onclick="setBias(this)">— Neu</button></div></div>
        <div class="tf-row"><div class="lbl">1 Hora</div><div class="bias-btns"><button class="bb" data-tf="h1" data-v="ALCISTA" onclick="setBias(this)">▲ Alc</button><button class="bb" data-tf="h1" data-v="BAJISTA" onclick="setBias(this)">▼ Baj</button><button class="bb" data-tf="h1" data-v="NEUTRO" onclick="setBias(this)">— Neu</button></div></div>
      </div>
    </div>

    <div>
      <div class="sec-title">Nivel Blanco (precio objetivo)</div>
      <div class="field">
        <label>Precio cierre vela mayor volumen</label>
        <input type="number" id="precio-manual" placeholder="23217.25" step="0.25">
      </div>
      <div class="field">
        <label>Escenario</label>
        <select id="escenario">
          <option value="1">Escenario 1 — Mínimo con volumen alto (manipulación clara)</option>
          <option value="2">Escenario 2 — No lleva mínimo, rebote, esperar 2da manipulación</option>
          <option value="3">Escenario 3 — Volumen pre-market no testeado en sesión</option>
        </select>
      </div>
      <div class="field">
        <label>Tipo de entrada SHORT</label>
        <select id="tipo-short">
          <option value="na">N/A (entrada LONG)</option>
          <option value="arriba">2da manipulación ARRIBA estructura (92%)</option>
          <option value="premkt">2da manipulación desde pre-market (54%)</option>
        </select>
      </div>
      <div class="field">
        <label>Vol. pre-market no testeado (nivel)</label>
        <input type="number" id="vol-premkt" placeholder="23100.50" step="0.25">
      </div>
    </div>

    <div>
      <div class="sec-title">Contexto adicional</div>
      <div class="field">
        <label>Notas / niveles clave</label>
        <textarea id="notas" placeholder="Nivel de resistencia en 23,450&#10;Soporte en 23,150..."></textarea>
      </div>
    </div>

    <button id="btn-analyze" onclick="runAnalysis()">▶ ANALIZAR</button>

    <div style="text-align:center;font-size:9px;color:var(--muted);padding-top:4px;">
      Capital: $50,000 · Riesgo: 2% = $1,000/trade · NQ Full
    </div>

  </div><!-- /sidebar -->

  <!-- CONTENT -->
  <div id="content">

    <!-- DECISION HERO -->
    <div id="dec-card">
      <div id="dec-signal" class="WAIT">WAIT</div>
      <div class="risk-grid">
        <div class="ri"><div class="rl">Entrada</div><div class="rv" id="rv-entry">—</div></div>
        <div class="ri"><div class="rl">Stop Loss</div><div class="rv r" id="rv-sl">—</div></div>
        <div class="ri"><div class="rl">Take Profit</div><div class="rv g" id="rv-tp">—</div></div>
        <div class="ri"><div class="rl">Contratos</div><div class="rv a" id="rv-contr">—</div></div>
        <div class="ri">
          <div class="rl">Riesgo</div>
          <div class="rv r" id="rv-risk">—</div>
          <div style="font-size:9px;color:var(--muted)" id="rv-risk-pct">—% capital</div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;">
        <div id="conf-badge">—</div>
        <div id="rr-badge" style="font-size:10px;font-weight:700;color:var(--amber);">RR 1:1</div>
        <div style="font-size:9px;color:var(--muted)">Ganancia</div>
        <div style="font-size:13px;font-weight:700;color:var(--green)" id="rv-gain">—</div>
        <div style="font-size:9px;color:var(--muted)" id="rv-gain-pct">—% capital</div>
      </div>
    </div>

    <!-- AGENTS -->
    <div class="agents-grid">
      <div class="ag-card" id="card-ag1">
        <div class="ag-hdr"><span class="ag-id">AG1</span><span class="ag-name">Sesión NY</span><div class="ag-dot" id="dot-ag1"></div></div>
        <div class="ag-body" id="out-ag1">Esperando análisis...</div>
      </div>
      <div class="ag-card" id="card-ag2">
        <div class="ag-hdr"><span class="ag-id">AG2</span><span class="ag-name">Estructura</span><div class="ag-dot" id="dot-ag2"></div></div>
        <div class="ag-body" id="out-ag2">Esperando análisis...</div>
      </div>
      <div class="ag-card" id="card-ag3">
        <div class="ag-hdr"><span class="ag-id">AG3</span><span class="ag-name">Volumen Up/Down</span><div class="ag-dot" id="dot-ag3"></div></div>
        <div class="ag-body" id="out-ag3">Esperando análisis...</div>
      </div>
      <div class="ag-card" id="card-ag4">
        <div class="ag-hdr"><span class="ag-id">AG4</span><span class="ag-name">Decisión</span><div class="ag-dot" id="dot-ag4"></div></div>
        <div class="ag-body" id="out-ag4">Esperando AG1+AG2+AG3...</div>
      </div>
      <div class="ag-card" id="card-ag5">
        <div class="ag-hdr"><span class="ag-id">AG5</span><span class="ag-name">Gestión Riesgo</span><div class="ag-dot" id="dot-ag5"></div></div>
        <div class="ag-body" id="out-ag5">Esperando decisión...</div>
      </div>
      <div class="ag-card" id="card-ag6">
        <div class="ag-hdr"><span class="ag-id">AG6</span><span class="ag-name">Alerta</span><div class="ag-dot" id="dot-ag6"></div></div>
        <div class="ag-body" id="out-ag6">Esperando setup completo...</div>
      </div>
    </div>

    <!-- BOTTOM ROW -->
    <div class="bottom-row">

      <!-- Telegram -->
      <div class="panel">
        <div class="panel-hdr">
          <span class="panel-title">Telegram · Lenintrader Bot</span>
          <span id="tg-status" style="font-size:9px;color:var(--muted);">—</span>
        </div>
        <div class="panel-body">
          <div id="tg-preview">El mensaje de alerta aparecerá aquí una vez completado el análisis.</div>
          <button id="btn-tg" onclick="sendTelegram()" disabled>▶ Enviar a Telegram</button>
        </div>
      </div>

      <!-- Log -->
      <div class="panel">
        <div class="panel-hdr">
          <span class="panel-title">Log Operaciones</span>
          <button style="background:transparent;border:none;color:var(--muted);font-size:9px;cursor:pointer;" onclick="clearLog()">✕ limpiar</button>
        </div>
        <div id="log-body">
          <div class="log-row log-hdr">
            <span>Hora NY</span><span>Señal</span><span>Entrada</span><span>SL</span><span>TP</span><span>Contr.</span>
          </div>
          <div class="log-empty" id="log-empty">Sin operaciones registradas</div>
        </div>
      </div>

    </div>
  </div><!-- /content -->
</div><!-- /layout -->

<!-- MODAL CONFIG -->
<div id="modal">
  <div class="modal-box">
    <h3>⚙ Configuración</h3>
    <p>Configura las credenciales del sistema. Se guardan localmente en tu navegador.</p>
